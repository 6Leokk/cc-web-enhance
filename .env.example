# Web 登录密码（可选，不设则首次启动自动生成随机密码）
# CC_WEB_PASSWORD=your-password-here

# 服务监听端口（默认 8083）
CC_WEB_PORT=8083

# 服务监听地址（默认 127.0.0.1；direct/local、ngrok、frp 模式建议保持该值）
CC_WEB_HOST=127.0.0.1

# 统一访问模式：direct / public / ngrok / frp
# 默认 direct + local，只开放本机浏览器访问
CC_WEB_ACCESS_MODE=direct

# direct 模式下的作用域：local / lan
CC_WEB_DIRECT_SCOPE=local

# 仅在需要对外发布明确的公共 URL 时填写；值必须是 origin，不要带 path/query/hash
CC_WEB_PUBLIC_URL=

# 仅在服务位于受信任反向代理之后时开启，才会信任 X-Forwarded-For
# CC_WEB_TRUST_PROXY=1

# 兼容旧变量；如同时设置，CC_WEB_HOST/CC_WEB_PORT 优先
# PORT=8083
# HOST=127.0.0.1

# ngrok：适合没有公网 IP、但希望提供远程访问的场景
# 真实 token 只写入本地 .env，不要提交到仓库
# NGROK_AUTHTOKEN=YOUR_NGROK_AUTHTOKEN
# NGROK_DOMAIN=YOUR_DOMAIN
# NGROK_BASIC_AUTH=user:pass
# NGROK_AUTO_START=1

# 内置 frp 内网穿透（保留为自托管高级路径；默认 disabled）
# 用户流：npm run frp:download -> npm run frp:setup -> npm start
# 真实 token 只写入本地 .env 或 frp/conf/*.toml，不要提交到仓库
# FRP_MODE=disabled
# 兼容旧配置：FRP_MODE=client / FRP_MODE=server
# FRP_MODE=client
# FRP_TYPE=ip
# FRP_SERVER_ADDR=YOUR_FRP_SERVER_IP
# FRP_SERVER_PORT=7000
# FRP_TOKEN=YOUR_FRP_TOKEN
# FRP_PUBLIC_PORT=YOUR_PUBLIC_PORT
# FRP_CUSTOM_DOMAIN=YOUR_DOMAIN
# FRP_SUBDOMAIN=
# FRP_BIND_PORT=7000
# FRP_VHOST_HTTP_PORT=
# FRP_LOCAL_IP=127.0.0.1
# FRP_LOCAL_PORT=8083
# FRP_AUTO_START=1
# FRP_CONFIG_FILE=
# FRP_EXTRA_TOML_FILE=
# 大陆/镜像下载可选项：直接镜像下载必须同时提供 FRP_VERSION 和 FRP_DOWNLOAD_SHA256
# FRP_DOWNLOAD_GITHUB_PROXY_BASE=https://gh-proxy.com/
# FRP_DOWNLOAD_BASE_URL=
# FRP_DOWNLOAD_URL=
# FRP_DOWNLOAD_SHA256=
# FRP_VERSION=

# 仅在你明确接受“自动杀掉占用端口的进程”时开启
# CC_WEB_KILL_PORT_OCCUPANT=1

# Claude CLI 路径（默认在 PATH 中查找 claude）
CLAUDE_PATH=claude

# Codex CLI 路径（默认在 PATH 中查找 codex）
CODEX_PATH=codex

# PushPlus Token（可选，首次启动会自动迁移到 config/notify.json）
PUSHPLUS_TOKEN=

# Bark 通知（可选，首次启动会自动迁移到 config/notify.json）
# BARK_DEVICE_KEY=your-bark-device-key
# BARK_SERVER_URL=https://api.day.app
# BARK_GROUP=CC-Web
# BARK_LEVEL=active
# BARK_SOUND=
# BARK_ICON=
# BARK_URL=
