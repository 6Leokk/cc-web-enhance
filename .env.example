# Web 登录密码（可选，不设则首次启动自动生成随机密码）
# CC_WEB_PASSWORD=your-password-here

# 服务监听端口（默认 8083）
CC_WEB_PORT=8083

# 服务监听地址（默认 127.0.0.1；frp 模式建议保持该值）
CC_WEB_HOST=127.0.0.1

# 兼容旧变量；如同时设置，CC_WEB_HOST/CC_WEB_PORT 优先
# PORT=8083
# HOST=127.0.0.1

# 内置 frp 内网穿透（默认禁用；需要时改为 client 或 server）
# 用户流：npm run frp:download -> npm run frp:setup -> npm start
# 真实 token 只写入本地 .env 或 frp/conf/*.toml，不要提交到仓库
# FRP_MODE=client
# FRP_TYPE=ip
# FRP_SERVER_ADDR=YOUR_FRP_SERVER_IP
# FRP_SERVER_PORT=7000
# FRP_TOKEN=YOUR_FRP_TOKEN
# FRP_PUBLIC_PORT=YOUR_PUBLIC_PORT
# FRP_CUSTOM_DOMAIN=YOUR_DOMAIN
# FRP_SUBDOMAIN=
# FRP_BIND_PORT=7000
# FRP_VHOST_HTTP_PORT=
# FRP_LOCAL_IP=127.0.0.1
# FRP_LOCAL_PORT=8083
# FRP_AUTO_START=1
# FRP_CONFIG_FILE=
# FRP_EXTRA_TOML_FILE=

# 仅在服务位于受信任反向代理之后时开启，才会信任 X-Forwarded-For
# CC_WEB_TRUST_PROXY=1

# 仅在你明确接受“自动杀掉占用端口的进程”时开启
# CC_WEB_KILL_PORT_OCCUPANT=1

# Claude CLI 路径（默认在 PATH 中查找 claude）
CLAUDE_PATH=claude

# Codex CLI 路径（默认在 PATH 中查找 codex）
CODEX_PATH=codex

# PushPlus Token（可选，首次启动会自动迁移到 config/notify.json）
PUSHPLUS_TOKEN=

# Bark 通知（可选，首次启动会自动迁移到 config/notify.json）
# BARK_DEVICE_KEY=your-bark-device-key
# BARK_SERVER_URL=https://api.day.app
# BARK_GROUP=CC-Web
# BARK_LEVEL=active
# BARK_SOUND=
# BARK_ICON=
# BARK_URL=
